// QUIZ PAGE
// ═══════════════════════════════════════
const QuizPage = ({ showXP }) => {
  const [qIdx, setQIdx] = useState(0);
  const [selected, setSelected] = useState(null);
  const [answered, setAnswered] = useState(false);
  const [score, setScore] = useState(0);
  const [done, setDone] = useState(false);
  const [time, setTime] = useState(30);
  const [difficulty, setDifficulty] = useState('medium');
  const q = QUIZ_QUESTIONS[qIdx];

  useEffect(() => {
    if (done || answered) return;
    const t = setInterval(() => {
      setTime(p => {
        if (p <= 1) { setAnswered(true); return 30; }
        return p - 1;
      });
    }, 1000);
    return () => clearInterval(t);
  }, [qIdx, done, answered]);

  const answer = (idx) => {
    if (answered) return;
    setSelected(idx);
    setAnswered(true);
    if (idx === q.ans) { setScore(p => p + 1); showXP(50, 'Correct answer! +50 XP'); }
  };

  const next = () => {
    if (qIdx < QUIZ_QUESTIONS.length - 1) { setQIdx(p => p + 1); setSelected(null); setAnswered(false); setTime(30); }
    else setDone(true);
  };

  if (done) return (
    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', minHeight: 400, textAlign: 'center' }}>
      <div style={{ fontSize: 80, marginBottom: 20 }} className="animate-victory">
        {score >= 3 ? '🏆' : score >= 2 ? '🥈' : '📚'}
      </div>
      <h2 style={{ fontSize: 32, fontWeight: 700, marginBottom: 8 }}>Quiz Complete!</h2>
      <div style={{ fontSize: 48, fontFamily: 'var(--font-display)', fontWeight: 900, color: score >= 3 ? 'var(--accent3)' : 'var(--accent)', marginBottom: 16 }}>
        {score}/{QUIZ_QUESTIONS.length}
      </div>
      <div style={{ color: 'var(--muted)', marginBottom: 24 }}>{score >= 3 ? 'Excellent work! You really know your stuff! 🔥' : score >= 2 ? 'Good job! Keep practicing to improve!' : 'Keep learning — you\'ll get there! 💪'}</div>
      <div style={{ display: 'flex', gap: 12 }}>
        <button className="btn btn-primary" onClick={() => { setQIdx(0); setScore(0); setDone(false); setSelected(null); setAnswered(false); setTime(30); }}>Try Again</button>
        <button className="btn btn-ghost">View Analysis</button>
      </div>
    </div>
  );

  return (
    <div style={{ maxWidth: 700, margin: '0 auto' }}>
      <div style={{ marginBottom: 20, display: 'flex', gap: 8 }}>
        {['easy','medium','hard','expert'].map(d => (
          <button key={d} className={`btn btn-sm ${difficulty === d ? 'btn-primary' : 'btn-ghost'}`} onClick={() => setDifficulty(d)} style={{ textTransform: 'capitalize' }}>{d}</button>
        ))}
      </div>

      <div className="card" style={{ padding: 32 }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 24 }}>
          <div style={{ display: 'flex', gap: 8 }}>
            {QUIZ_QUESTIONS.map((_,i) => (
              <div key={i} style={{ width: 32, height: 6, borderRadius: 3, background: i < qIdx ? 'var(--accent3)' : i === qIdx ? 'var(--accent)' : 'var(--border)' }} />
            ))}
          </div>
          <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
            <div style={{ width: 40, height: 40, borderRadius: '50%', border: `3px solid ${time <= 10 ? 'var(--danger)' : 'var(--accent)'}`, display: 'flex', alignItems: 'center', justifyContent: 'center', fontFamily: 'var(--font-display)', fontSize: 14, fontWeight: 700, color: time <= 10 ? 'var(--danger)' : 'var(--accent)', animation: time <= 10 ? 'pulse 0.5s infinite' : 'none' }}>{time}</div>
            <span style={{ fontSize: 12, color: 'var(--muted)' }}>Q{qIdx + 1} of {QUIZ_QUESTIONS.length}</span>
          </div>
        </div>

        <h2 style={{ fontSize: 20, fontWeight: 600, marginBottom: 24, lineHeight: 1.5 }}>{q.q}</h2>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 12, marginBottom: 24 }}>
          {q.opts.map((opt, i) => (
            <div key={i} className={`quiz-option ${answered ? (i === q.ans ? 'correct' : selected === i ? 'wrong' : '') : selected === i ? 'selected' : ''}`}
              onClick={() => answer(i)}>
              <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
                <div style={{ width: 28, height: 28, borderRadius: '50%', background: answered ? (i === q.ans ? 'var(--accent3)' : selected === i ? 'var(--danger)' : 'var(--border)') : 'var(--border)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 12, fontWeight: 700, flexShrink: 0 }}>
                  {answered ? (i === q.ans ? '✓' : selected === i ? '✗' : String.fromCharCode(65+i)) : String.fromCharCode(65+i)}
                </div>
                {opt}
              </div>
            </div>
          ))}
        </div>

        {answered && (
          <div style={{ padding: 16, borderRadius: 10, background: selected === q.ans ? 'rgba(52,211,153,0.1)' : 'rgba(248,113,113,0.1)', border: `1px solid ${selected === q.ans ? 'rgba(52,211,153,0.3)' : 'rgba(248,113,113,0.3)'}`, marginBottom: 20 }}>
            <div style={{ fontWeight: 600, marginBottom: 4, color: selected === q.ans ? 'var(--accent3)' : 'var(--danger)' }}>
              {selected === q.ans ? '✅ Correct! +50 XP' : '❌ Wrong!'}
            </div>
            <div style={{ fontSize: 13, color: 'var(--muted)' }}>{q.exp}</div>
          </div>
        )}

        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <div style={{ display: 'flex', gap: 8 }}>
            <span className="badge badge-green">Score: {score}</span>
            <span className="badge badge-blue">+{score * 50} XP</span>
          </div>
          {answered && <button className="btn btn-primary" onClick={next}>{qIdx < QUIZ_QUESTIONS.length - 1 ? 'Next Question →' : 'See Results 🏆'}</button>}
        </div>
      </div>
    </div>
  );
};

