const AdventurePage = ({ showXP }) => {
  const [currentLevel, setCurrentLevel] = useState(1);
  const [health, setHealth] = useState(100);
  const [bossHealth, setBossHealth] = useState(100);
  const [battling, setBattling] = useState(false);
  const [battleLog, setBattleLog] = useState([]);
  const [won, setWon] = useState(false);

  const levels = [
    { id: 1, name: 'The Forest of Arrays', boss: 'Array Dragon', icon: '🐉', unlocked: true, reward: '500 XP + Rare Sword', topic: 'Arrays & Loops' },
    { id: 2, name: 'Pointer Dungeon', boss: 'Pointer Phantom', icon: '👻', unlocked: currentLevel >= 2, reward: '800 XP + Shield', topic: 'Pointers & Memory' },
    { id: 3, name: 'Recursion Tower', boss: 'Recursive Giant', icon: '🗼', unlocked: currentLevel >= 3, reward: '1200 XP + Crown', topic: 'Recursion' },
    { id: 4, name: 'Algorithm Volcano', boss: 'Sort Demon', icon: '🌋', unlocked: currentLevel >= 4, reward: '2000 XP + Legend Badge', topic: 'Sorting Algorithms' },
  ];

  const attack = () => {
    if (battling) return;
    setBattling(true);
    const dmg = Math.floor(Math.random() * 25) + 10;
    const bossDmg = Math.floor(Math.random() * 20) + 5;
    setBossHealth(p => Math.max(0, p - dmg));
    setHealth(p => Math.max(0, p - bossDmg));
    setBattleLog(p => [`⚔️ You dealt ${dmg} damage!`, `🔥 Boss attacked for ${bossDmg} damage!`, ...p.slice(0, 4)]);
    
    setTimeout(() => {
      setBattling(false);
      setBossHealth(prev => {
        if (prev <= 0) { setWon(true); showXP(500, 'BOSS DEFEATED! Adventure Victory!'); }
        return prev;
      });
    }, 500);
  };

  const resetBattle = () => { setBossHealth(100); setHealth(100); setWon(false); setBattleLog([]); setCurrentLevel(p => p + 1); showXP(200, 'Level cleared! Moving to next zone!'); };

  return (
    <div>
      <div style={{ marginBottom: 24 }}>
        <h1 style={{ fontSize: 24, fontWeight: 700, marginBottom: 4 }}>⚔️ Adventure Learning Mode</h1>
        <p style={{ color: 'var(--muted)' }}>Fight AI bosses, complete coding missions, earn legendary rewards!</p>
      </div>

      {/* Map */}
      <div className="card" style={{ padding: 24, marginBottom: 20, background: 'linear-gradient(135deg, rgba(56,189,248,0.05), rgba(167,139,250,0.05))' }}>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: 16 }}>
          {levels.map(lv => (
            <div key={lv.id} onClick={() => lv.unlocked && setCurrentLevel(lv.id)}
              className="card" style={{ padding: 20, textAlign: 'center', cursor: lv.unlocked ? 'pointer' : 'not-allowed', opacity: lv.unlocked ? 1 : 0.5, border: currentLevel === lv.id ? '2px solid var(--accent)' : '1px solid var(--border)', background: currentLevel === lv.id ? 'rgba(56,189,248,0.1)' : 'var(--card)', transition: 'all 0.3s' }}>
              <div style={{ fontSize: 36, marginBottom: 8 }}>{lv.unlocked ? lv.icon : '🔒'}</div>
              <div style={{ fontWeight: 600, fontSize: 13, marginBottom: 4 }}>Level {lv.id}</div>
              <div style={{ fontSize: 11, color: 'var(--muted)', marginBottom: 6 }}>{lv.name}</div>
              <span className="badge badge-blue" style={{ fontSize: 9 }}>{lv.topic}</span>
              {currentLevel > lv.id && <div style={{ marginTop: 6 }}><span className="badge badge-green" style={{ fontSize: 9 }}>✓ Cleared</span></div>}
            </div>
          ))}
        </div>
      </div>

      {/* Battle Arena */}
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 20 }}>
        <div className="card" style={{ padding: 24, background: 'linear-gradient(135deg, rgba(248,113,113,0.05), rgba(167,139,250,0.05))' }}>
          <h3 style={{ fontWeight: 700, marginBottom: 20, textAlign: 'center' }}>⚔️ Battle Arena — {levels.find(l=>l.id===currentLevel)?.name}</h3>
          
          {won ? (
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 60, marginBottom: 16 }} className="animate-victory">🏆</div>
              <h3 style={{ color: 'var(--gold)', marginBottom: 8 }}>BOSS DEFEATED!</h3>
              <p style={{ color: 'var(--muted)', fontSize: 14, marginBottom: 12 }}>You earned: <strong style={{ color: 'var(--gold)' }}>{levels.find(l=>l.id===currentLevel)?.reward}</strong></p>
              <button className="btn btn-gold" onClick={resetBattle}>Next Level →</button>
            </div>
          ) : health <= 0 ? (
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 60, marginBottom: 16 }}>💀</div>
              <h3 style={{ color: 'var(--danger)', marginBottom: 8 }}>DEFEATED!</h3>
              <button className="btn btn-danger" onClick={() => { setHealth(100); setBossHealth(100); setBattleLog([]); }}>Retry</button>
            </div>
          ) : (
            <>
              {/* Player */}
              <div style={{ marginBottom: 20 }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 13, marginBottom: 6 }}>
                  <span>⚡ You (Lv.22)</span>
                  <span style={{ color: 'var(--accent3)' }}>{health}/100 HP</span>
                </div>
                <div className="progress-bar" style={{ height: 10 }}><div className="progress-fill-green progress-fill" style={{ width: `${health}%` }} /></div>
              </div>

              <div style={{ textAlign: 'center', padding: '20px 0', fontSize: 60 }}>{levels.find(l=>l.id===currentLevel)?.icon}</div>
              <div style={{ textAlign: 'center', fontSize: 14, color: 'var(--muted)', marginBottom: 8 }}>{levels.find(l=>l.id===currentLevel)?.boss}</div>

              {/* Boss */}
              <div style={{ marginBottom: 20 }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 13, marginBottom: 6 }}>
                  <span>👹 Boss</span>
                  <span style={{ color: 'var(--danger)' }}>{bossHealth}/100 HP</span>
                </div>
                <div className="progress-bar" style={{ height: 10 }}><div className="progress-fill" style={{ width: `${bossHealth}%`, background: 'linear-gradient(90deg, var(--danger), #ef4444)' }} /></div>
              </div>

              <div style={{ display: 'flex', gap: 8, justifyContent: 'center' }}>
                <button className="btn btn-danger" onClick={attack} style={{ animation: battling ? 'shake 0.3s' : 'none' }}>⚔️ Attack</button>
                <button className="btn btn-primary" onClick={() => { setHealth(p => Math.min(100, p + 20)); showXP(10, 'Used healing potion!'); }}>🧪 Heal</button>
                <button className="btn btn-ghost" onClick={() => showXP(50, 'Used special ability!')}>✨ Special</button>
              </div>
            </>
          )}
        </div>

        {/* Battle Log + Mission */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
          <div className="card" style={{ padding: 20, flex: 1 }}>
            <h4 style={{ fontWeight: 600, marginBottom: 12 }}>📜 Battle Log</h4>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontFamily: 'var(--font-code)', fontSize: 12 }}>
              {battleLog.length === 0 ? <span style={{ color: 'var(--muted)' }}>Start the battle to see the action!</span> : battleLog.map((log, i) => (
                <div key={i} style={{ color: log.includes('You') ? 'var(--accent3)' : 'var(--danger)', padding: '4px 8px', background: 'rgba(255,255,255,0.03)', borderRadius: 4 }}>{log}</div>
              ))}
            </div>
          </div>
          <div className="card" style={{ padding: 20 }}>
            <h4 style={{ fontWeight: 600, marginBottom: 12 }}>🎯 Zone Mission</h4>
            <div style={{ fontSize: 13, marginBottom: 8 }}>Answer a coding question to deal 2x damage!</div>
            <div style={{ padding: 12, background: 'var(--bg2)', borderRadius: 8, fontSize: 12, fontFamily: 'var(--font-code)', marginBottom: 12 }}>
              Q: What is the time complexity of array access?
            </div>
            <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
              {['O(n)','O(1)','O(log n)','O(n²)'].map(a => (
                <button key={a} onClick={() => { if (a === 'O(1)') { setBossHealth(p => Math.max(0, p - 40)); showXP(100, 'Correct! 2x damage dealt!'); setBattleLog(p => ['💥 CRITICAL HIT! 40 damage!', ...p]); } else setBattleLog(p => ['❌ Wrong answer!', ...p]); }}
                  className="badge badge-blue" style={{ cursor: 'pointer', padding: '6px 12px', fontSize: 12 }}>{a}</button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

