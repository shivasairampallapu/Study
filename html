    { id: 'achievements', icon: 'fa-medal', label: 'Achievements' },
    { id: 'settings', icon: 'fa-cog', label: 'Settings' },
  ];

  if (page === 'hero') return (
    <>
      <HeroSection onNavigate={navigate} />
      {xpNotif && <XPNotification xp={xpNotif.amount} message={xpNotif.message} onDone={() => setXpNotif(null)} />}
    </>
  );
  if (page === 'login') return (
    <>
      <LoginPage onNavigate={navigate} />
      {xpNotif && <XPNotification xp={xpNotif.amount} message={xpNotif.message} onDone={() => setXpNotif(null)} />}
    </>
  );

  return (
    <div style={{ display: 'flex', minHeight: '100vh' }}>
      {/* Sidebar */}
      <div className={`sidebar ${sidebarOpen ? 'open' : ''}`}>
        {/* Top XP bar */}
        <div className="xp-bar" />
        {/* Logo */}
        <div style={{ padding: '16px 24px 8px', marginBottom: 8 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
            <div style={{ width: 32, height: 32, borderRadius: 8, background: 'linear-gradient(135deg, var(--accent), var(--accent2))', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 16 }}>⚡</div>
            <span style={{ fontFamily: 'var(--font-display)', fontSize: 14, fontWeight: 700, letterSpacing: 0.5 }} className="grad-text">LearnQuest AI</span>
          </div>
        </div>

        {/* User */}
        <div style={{ padding: '12px 24px', marginBottom: 16, borderBottom: '1px solid var(--border)' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
            <div style={{ width: 36, height: 36, borderRadius: '50%', background: 'linear-gradient(135deg, var(--accent3), var(--accent2))', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 16 }}>⚡</div>
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ fontSize: 13, fontWeight: 600 }}>Shiva Sai Ram</div>
              <div style={{ fontSize: 11, color: 'var(--muted)' }}>Level 22 • {userXP.toLocaleString()} XP</div>
            </div>
            <div style={{ fontSize: 18 }}>🔥</div>
          </div>
          <div className="progress-bar" style={{ marginTop: 8 }}>
            <div className="progress-fill" style={{ width: `${(userXP % 10000) / 100}%` }} />
          </div>
        </div>

        {/* Nav */}
        <div className="scrollable" style={{ flex: 1, padding: '0 0 16px' }}>
          {navItems.map(item => (
            <div key={item.id} className={`sidebar-item ${activePage === item.id ? 'active' : ''}`} onClick={() => { setActivePage(item.id); setSidebarOpen(false); }}>
              <i className={`fa ${item.icon}`} />
              <span>{item.label}</span>
              {item.id === 'adventure' && <span className="badge badge-red" style={{ fontSize: 9, marginLeft: 'auto' }}>NEW</span>}
              {item.id === 'ai-chat' && <span className="badge badge-green" style={{ fontSize: 9, marginLeft: 'auto' }}>●</span>}
            </div>
          ))}
        </div>

        {/* Bottom */}
        <div style={{ padding: '16px 24px', borderTop: '1px solid var(--border)' }}>
          <div style={{ display: 'flex', gap: 8 }}>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 11, color: 'var(--muted)' }}>Daily Goal</div>
              <div className="progress-bar" style={{ marginTop: 4 }}><div className="progress-fill" style={{ width: '70%' }} /></div>
            </div>
            <div style={{ fontSize: 11, color: 'var(--accent)', fontWeight: 600 }}>70%</div>
          </div>
          <div style={{ marginTop: 10, fontSize: 12, color: 'var(--muted)', cursor: 'pointer' }} onClick={() => setPage('hero')}>
            <i className="fa fa-arrow-left" style={{ marginRight: 6 }} />Back to Home
          </div>
        </div>
      </div>

      {/* Main */}
      <div className="main-content">
        {/* Top bar */}
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 24, position: 'sticky', top: 0, zIndex: 50, background: 'var(--bg)', paddingTop: 4, paddingBottom: 16, borderBottom: '1px solid var(--border)' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
            <button onClick={() => setSidebarOpen(p => !p)} style={{ display: 'none', background: 'none', border: 'none', fontSize: 20, color: 'var(--text)', cursor: 'pointer' }} className="mobile-menu-btn">☰</button>
            <div style={{ fontFamily: 'var(--font-display)', fontSize: 13, fontWeight: 700, color: 'var(--muted)' }}>
              {navItems.find(n => n.id === activePage)?.label}
            </div>
          </div>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '6px 12px', background: 'rgba(251,191,36,0.1)', borderRadius: 20, border: '1px solid rgba(251,191,36,0.3)' }}>
              <span style={{ fontSize: 14 }}>🪙</span>
              <span style={{ fontFamily: 'var(--font-display)', fontSize: 13, fontWeight: 700, color: 'var(--gold)' }}>2,840</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '6px 12px', background: 'rgba(56,189,248,0.1)', borderRadius: 20, border: '1px solid rgba(56,189,248,0.3)' }}>
              <span style={{ fontSize: 14 }}>⚡</span>
              <span style={{ fontFamily: 'var(--font-display)', fontSize: 13, fontWeight: 700, color: 'var(--accent)' }}>{userXP.toLocaleString()}</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '6px 12px', background: 'rgba(248,113,113,0.1)', borderRadius: 20, border: '1px solid rgba(248,113,113,0.3)' }}>
              <span style={{ fontSize: 14 }}>🔥</span>
              <span style={{ fontFamily: 'var(--font-display)', fontSize: 13, fontWeight: 700, color: 'var(--danger)' }}>21</span>
            </div>
            <button style={{ background: 'none', border: 'none', fontSize: 20, cursor: 'pointer' }} onClick={() => setDarkMode(p => !p)}>
              {darkMode ? '☀️' : '🌙'}
            </button>
          </div>
        </div>

        {/* Page Content */}
        <div className="animate-fadeUp">
          {activePage === 'dashboard' && <Dashboard userXP={userXP} setUserXP={setUserXP} showXP={showXP} />}
          {activePage === 'subjects' && <SubjectsPage showXP={showXP} />}
          {activePage === 'ai-chat' && <AIChatPage showXP={showXP} />}
          {activePage === 'code' && <CodeEditorPage showXP={showXP} />}
          {activePage === 'quiz' && <QuizPage showXP={showXP} />}
          {activePage === 'roadmap' && <RoadmapPage showXP={showXP} />}
          {activePage === 'adventure' && <AdventurePage showXP={showXP} />}
          {activePage === 'leaderboard' && <LeaderboardPage />}
          {activePage === 'community' && <CommunityPage showXP={showXP} />}
          {activePage === 'achievements' && <AchievementsPage />}
          {activePage === 'settings' && <SettingsPage darkMode={darkMode} setDarkMode={setDarkMode} />}
        </div>
      </div>

      {/* XP Notification */}
      {xpNotif && <XPNotification xp={xpNotif.amount} message={xpNotif.message} onDone={() => setXpNotif(null)} />}
    </div>
  );
};

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
